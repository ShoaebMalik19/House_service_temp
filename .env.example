# Environment Template File
# -----------------------------------------------------------------------------
# Copy this file to .env.local and fill in your actual values.
# NEVER commit .env.local or any real secrets to Git.

# The public URL of the website (used for SEO metadata and canonical links)
NEXT_PUBLIC_SITE_URL="https://summitbuilders.com"

# Endpoint for the contact form and estimate wizard (e.g. Formspree, Web3Forms URL)
# If left empty, forms will simulate success for demonstration purposes.
NEXT_PUBLIC_FORM_ENDPOINT="https://api.web3forms.com/submit"
NEXT_PUBLIC_FORM_ACCESS_KEY="your-web3forms-access-key-here"
